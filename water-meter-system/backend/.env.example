# Database
DATABASE_URL="postgresql://USERNAME:PASSWORD@HOST:6543/postgres?pgbouncer=true&connection_limit=1&schema=public"

# JWT
JWT_SECRET="replace-with-a-long-random-secret"
JWT_EXPIRES_IN=24h

# Server
PORT=5000
NODE_ENV=development

# Frontend origin
FRONTEND_ORIGIN="http://localhost:5173"

# File Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760

# Safety
ALLOW_PROD_SEED=false
